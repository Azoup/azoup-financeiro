{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "node scripts/postinstall-deps.js",
  "devCommand": "npx expo start --web",
  "framework": null,
  "cleanUrls": true,
  "env": {
    "LD_LIBRARY_PATH": "",
    "NODE_USE_SYSTEM_CA": "1"
  },
  "functions": {
    "api/nfe/**/*.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/:path*",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/boleto/consultar-pendentes",
      "schedule": "0 11 * * *"
    }
  ]
}
