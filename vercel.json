{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "node scripts/postinstall-deps.js",
  "devCommand": "npx expo start --web",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/:path*",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/boleto/consultar-pendentes",
      "schedule": "*/30 * * * *"
    }
  ]
}
