# Copie para .env na raiz (desenvolvimento local). Não commite o .env.

EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# --- Deploy na Vercel (obrigatório para login funcionar) ---
# Project → Settings → Environment Variables → Add:
#   Nome: EXPO_PUBLIC_SUPABASE_URL     Valor: https://xxx.supabase.co
#   Nome: EXPO_PUBLIC_SUPABASE_ANON_KEY   Valor: eyJhbG...
# Vercel — API NFS-e (/api/nfe/*) e boleto Sicoob (/api/boleto/*)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
CERT_ENCRYPTION_KEY=chave_secreta_min_16_chars_para_senha_certificado
# Opcional em app nativo: mesma URL da Vercel para APIs serverless
# EXPO_PUBLIC_NFE_API_URL=https://seu-app.vercel.app
# Cron Vercel — consulta boletos pagos no Sicoob a cada 30 min
CRON_SECRET=invente_uma_string_longa_e_secreta
#
# Na Vercel: Project → Settings → Environment Variables
#   EXPO_PUBLIC_SUPABASE_URL      (mesmo valor do front)
#   EXPO_PUBLIC_SUPABASE_ANON_KEY (mesmo valor do front)
#   SUPABASE_SERVICE_ROLE_KEY     (Supabase → Settings → API → service_role)
#   CERT_ENCRYPTION_KEY           (invente uma string longa, ex. 32+ caracteres)
# Depois: Redeploy
