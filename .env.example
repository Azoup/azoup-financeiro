# Copie para .env na raiz do projeto (não commite segredos em repositório público)

EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# --- Deploy na Vercel ---
# 1. Conecte o repositório Git na Vercel (Framework: Other — o vercel.json já define o build).
# 2. Em Settings → Environment Variables, adicione as duas variáveis acima
#    (Production, Preview e Development).
# 3. Faça deploy / redeploy. O build gera a pasta dist com expo export --platform web.
